{
    "name": "gafotas/headless-news-theme",
    "description": "A minimal headless wordpress theme for a news site.",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Gafotas\\HeadlessNewsTheme\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Denis Alemán"
        }
    ],
    "scripts": {
        "lint": "phpcs",
        "fix": "phpcbf"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.13",
        "wp-coding-standards/wpcs": "^3.3"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
